#include<iostream>
using namespace std;
void transform(char *str) {
    char replace = 'a';
    for (int i = 0; str[i] != '\0'; i++) {
        if (str[i] == '*') {
            str[i] = replace;
            replace++;
        }
    }
}
int main() {
    char s[100] = "doro*ro*hyak*kimar*u";
    transform(s);
    cout << s << endl;
    return 0;
}
