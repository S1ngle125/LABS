//#define NDEBUG
#include<cassert>
#include<iostream>
using namespace std;
char *find_money(char *str) {
    char *aim = "money";
    for (char *p=str;*p!='\0';p++) {
        char *s = p;
        char *t = aim;
        while (*t != '\0' and *s == *t) {
            t++;
            s++;
        }
        if (*t == '\0') {
            return p;
        }
    }
    return nullptr;
}
int main()
{
    {
        {
            char s[]{"thereisnomonyhere"};
            assert(find_money(s) == nullptr);
        }

        {
            char s[]{"woohoo, money!"};
            assert(find_money(s) == s + 8);
        }

        {
            char s[]{"wait, money here, money there, which one is correct?"};
            assert(find_money(s) == s + 6);
        }

        cout << "SUCCESS!" << endl;
    }
    {   
        {
            char s[]{"i found maney"};
            assert(find_money(s) == nullptr);
        }
        {
            char s[]{"can you borrow me some money?"};
            assert(find_money(s) == s + 23);
        }
        {
            char s[]{"moneymoneymoney"};
            assert(find_money(s) == s);
        }
        cout << "SUCCESS!" << endl;
    }
}


