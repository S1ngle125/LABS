#include<iostream>
#include<vector>
using namespace std;
int main() {
    int n,x,y;
    cin >> n >> x >> y;
    vector<vector<char>> doska(n,vector<char>(n, '.'));
    doska[x][y] = 'Q';
    int dx[] = {-1, -1, -1, 0, 0, 1, 1, 1};
    int dy[] = {-1, 0, 1, -1, 1, -1, 0, 1};
    for (int dir=0;dir<8;dir++) {
        for(int step = 1;;step++) {
            int nx=x+dx[dir] * step;
            int ny=y+dy[dir] * step;
            if (nx < 0 or nx >= n or ny < 0 or ny >= n) {
                break;
            }
            doska[nx][ny] = '*';
        }
    }
    for (int i = 0;i<n;++i) {
        for (int j=0;j<n;j++) {
            cout << doska[i][j];
            if (j < n - 1) {
                cout << " ";
            }
        }
        cout << endl;
    }
}
