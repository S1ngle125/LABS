//#define NDEBUG
#include<cassert>
#include<iostream>
using namespace std;
bool is_pal(double *a, const int n) {
    double *l = a;
    double *r = a + n - 1;
    while (l<r) {
        if (*l != *r) {
            return false;
        }
        ++l;
        --r;
    }
    return true;
}
int main() {
    {
        {
            double a[]{1,2,3,2,1};        
            assert(is_pal(a, 5));
        }
        
        {
            double a[]{1,-2,3,4,999,4,3,-2,1};        
            assert(is_pal(a, 9));
        }
        
        {
            double a[]{1,2,3,3,1};        
            assert(!is_pal(a, 5));
        }
                
        {
            double a[]{-77,23,365,366,23,-77};        
            assert(!is_pal(a, 6)); 
        }        
        cout << "SUCCESS!" << endl;
    }
    {   
        {
            double a[]{2,2,3,2,2};
            assert(is_pal(a,5));
        }
        {
            double a[]{1,2,3,4,4,3,2,1};
            assert(is_pal(a,8));
        }
        {
            double a[]{1,2,3,2};
            assert(!is_pal(a,4));
        }
        {
            double a[]{1,2,2,1,1};
            assert(!is_pal(a,5));
        }
        cout << "SUCCESS!" << endl;
    }
}


