#include <iostream>
#include <vector>
using namespace std;
int main() {
    int n, x, y;
    cin >> n >> x >> y;
    vector<vector<char>> doska(n, vector<char>(n, '.'));
    doska[x][y] = 'K';
    int dx[] = {-2, -2, -1, -1, 1, 1, 2, 2};
    int dy[] = {-1, 1, -2, 2, -2, 2, -1, 1};
    for (int i = 0; i < 8; i++) {
        int nx = x + dx[i];
        int ny = y + dy[i];
        if (nx >= 0 && nx < n && ny >= 0 && ny < n) {
            doska[nx][ny] = '*';
        }
    }
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cout << doska[i][j];
            if (j < n - 1) cout << " ";
        }
        cout << endl;
    }
}


