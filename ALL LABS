//#define NDEBUG
#include<cassert>
#include<iostream>
using namespace std;
void sort3(double *a, double *b, double *c) {
    if (*a > *b) {
        double temp = *a;
        *a = *b;
        *b = temp;
    }
    if (*a > *c) {
        double temp = *a;
        *a = *c;
        *c = temp;
    }
    if (*b > *c) {
        double temp = *b;
        *b = *c;
        *c = temp;
    }
}
int main() {
    {
        {
            double a=1, b=2, c=3;
            sort3(&a,&b,&c);
            assert(a==1 && b==2 && c==3);
        }
        
        {
            double a=-1, b=-2, c=-3;
            sort3(&a,&b,&c);
            assert(a==-3 && b==-2 && c==-1);
        }

        {
            double a=100, b=-10000, c=3.14;
            sort3(&a,&b,&c);
            assert(a==-10000 && b==3.14 && c==100);
        }

        cout << "SUCCESS!" << endl;
    }
    {
        {
            double a=10, b=20, c=15;
            sort3(&a,&b,&c);
            assert(a==10 and b==15 and c==20);
        }
        {
            double a=3.14, b=4, c=3.139;
            sort3(&a,&b,&c);
            assert(a==3.139 and b==3.14 and c==4);
        }    
        {
            double a=-1000, b=1000, c=0;
            sort3(&a,&b,&c);
            assert(a==-1000 and b==0 and c==1000);
        }
        cout << "SUCCESS!" << endl;
    }
}


