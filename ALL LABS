//#define NDEBUG
#include<cassert>
#include<iostream>
using namespace std;
int range(int *a, const int n) {
    int *p = a;
    int mi = *p;
    int ma = *p;
    for (int *p=a;p<a+n;p++) {
        if (*p < mi) {
            mi = *p;
        }
        if (*p > ma) {
            ma = *p;
        }
    }
    return ma-mi;
}
int main() {
    {
        {
            int a[] = {1,2,3,4,5,6,7};               
            assert(range(a, 7)==6);
        }
        {
            int a[] = {-1,99,-5,4,28,-99,66,0};               
            assert(range(a, 8)==198);
        }        
        {
            int a[] = {1000,1000,1000,1000};               
            assert(range(a, 4)==0);
        }        
        cout << "SUCCESS!" << endl;
    }
    {
        {
            int a[] = {5,1,8,14,-2,0};
            assert(range(a,6)==16);
        }
        {
            int a[] = {0,0,0,0};
            assert(range(a,4)==0);
        }
        {
            int a[] = {1,1,2,2,3,3,4,4};
            assert(range(a,8)==3);
        }
        cout << "SUCCESS!" << endl;
    }
}


