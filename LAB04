#include<fstream>  // .  .  .  .  .  .  .  .  .  .  .  .  ..  .  .  .  .  .  ..  .  .    .  ..    .  .  . LAB04-A1
#include<sstream>
#include<iostream>
#include<ctime>
#include<cstdlib>
using namespace std;
string random_n(int count, int minv, int maxv) {
    string result = "";
    for (int i = 0; i < count; ++i) {
        int random_number = minv + rand() % (maxv - minv + 1);
        result += to_string(random_number);
        if (i < 4) {
            result += " ";
        }
    }
    return result;
}
int main(){
    srand(time(0));
    for(int i = 1; i < 4; ++i) {
        cout << "Creating file prob" << i << "_in.txt" << endl;
        ofstream create("prob" + to_string(i) + "_in.txt");
        create << random_n(5,1,100) << endl;
        create << random_n(5,1,100) << endl;
        create << random_n(5,1,100) << endl;
        create.close();
        ifstream infile("prob" + to_string(i) + "_in.txt");
        ofstream outfile("prob" + to_string(i) + "_out.txt");
        if (!infile.is_open()) {
            cerr << "Error" << endl;
        }
        string line;
        while(getline(infile, line)) {
            if (line.empty()) {
                continue;
            }
            stringstream ss(line);
            int num;
            int ma = -99999;
            bool has_number = false;
            while (ss >> num) {
                has_number = true;
                if (num > ma) {
                    ma = num;
                }
            }
            if (has_number) {
                outfile << ma << endl;
                cout << "Max in " << line << ": " << ma << endl;
            }
        }
        infile.close();
        outfile.close();
        cout << "File number " << i << " is ready!" << endl;
    }
    cout << "All files are ready!" << endl;
}



#include <iostream>    //    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    LAB04-A2
#include <fstream>
#include <string>
#include <sstream>
using namespace std;
void file_process(const string& input, const string& output) {
    ifstream infile(input);
    ofstream outfile(output);
    string line;
    while (getline(infile, line)) {
        stringstream ss(line);
        string word;
        bool firstWord = true;
        while (ss >> word) {
            if (!firstWord) outfile << " ";
            firstWord = false;
            if (word.length() <= 1) {
                outfile << word;
            } 
            else {
                outfile << word[0];
                for (int i = 1; i < word.length(); i++) {
                    outfile << "*" << word[i];
                }
            }
        }
        outfile << endl;
    }
    infile.close();
    outfile.close();
}
void file_create(const string& filename, const string& inside) {
    ofstream file(filename);
    file << inside;
    file.close();
}
int main() {
    file_create("prob2_in.txt", "I will be a Pirate King\n");
    file_create("prob3_in.txt", "Hello World\n");
    file_create("prob4_in.txt", "44 555 6666\n");
    file_process("prob2_in.txt", "prob2_out.txt");
    file_process("prob3_in.txt", "prob3_out.txt");
    file_process("prob4_in.txt", "prob4_out.txt");
}



