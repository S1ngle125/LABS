#include <iostream>
#include <string>
#include <vector>
#include <sstream>
using namespace std;
class TextReader {
public:
    ifstream inputFile;
    ofstream outputFile;
    TextReader() {}
    TextReader(const string& inputFilename, const string& outputFilename) {
        inputFile.open(inputFilename);
        if (!inputFile.is_open()) {
            cerr << "Error: Cannot open input file!" << endl;
            exit(1);
        }
        
        outputFile.open(outputFilename);
        if (!outputFile.is_open()) {
            cerr << "Error: Cannot open output file!" << endl;
            exit(1);
        }
    }
    ~TextReader() {
        if (inputFile.is_open()) {
            inputFile.close();
            cout << "Input file closed!" << endl;
        }
        if (outputFile.is_open()) {
            outputFile.close();
            cout << "Output file closed!" << endl;
        }
    }
    vector<string> words() {
        vector<string> wordList;
        string line;
        inputFile.clear();
        inputFile.seekg(0);
        while (getline(inputFile, line)) {
            stringstream ss(line);
            string word;
            while (ss >> word) {
                wordList.push_back(word);
            }
        }
        return wordList;
    }
    void caesar_encrypt(int x) {
        inputFile.clear();
        inputFile.seekg(0);
        string line;
        while (getline(inputFile, line)) {
            string encryptedLine = "";
            for (char ch : line) {
                if (ch >= 'a' && ch <= 'z') {
                    char encryptedChar = ((ch - 'a' + x) % 26) + 'a';
                    encryptedLine += encryptedChar;
                } 
                else {
                    encryptedLine += ch;
                }
            }
            outputFile << encryptedLine << endl;
        }
    }
};
int main() {
    cout << "TEST 1: Creating input file" << endl;
    ofstream makeFile("test.txt");
    makeFile << "hello world" << endl;
    makeFile << "this is test" << endl;
    makeFile << "caesar cipher example" << endl;
