#include <fstream>
#include <vector>
#include <string>
#include <random>
#include <ctime>
using namespace std;
class Nonsense_Gen {
private:
    vector<string> dictionary;
    int counter;
    mt19937 rng;
public:
    Nonsense_Gen(const string& dictFile = "Cool_dictionary.txt") : counter(1) {
        rng.seed(time(nullptr));
        ifstream dictStream(dictFile);
        string word;
        while (dictStream >> word) {
            dictionary.push_back(word);
        }
        dictStream.close();
    }
    void generate(int wordsPerFile = 10, int wordsPerLine = 5) {
        if (dictionary.empty()) return;
        string filename = "nonsense_" + to_string(counter) + ".txt";
        ofstream outFile(filename);
        uniform_int_distribution<int> dist(0, dictionary.size() - 1);
        for (int i = 0; i < wordsPerFile; i++) {
            outFile << dictionary[dist(rng)];
            if (i < wordsPerFile - 1) {
                if ((i + 1) % wordsPerLine == 0) {
                    outFile << "\n";
                } 
                else {
                    outFile << " ";
                }
            }
        }
        outFile << "\n";
        outFile.close();
        counter++;
    }
    int getCounter() const { 
        return counter; 
    }
};
int main() {
    ofstream dict("Cool_dictionary.txt");
    dict << "C++ C RUST PYTHON ASM PHP RUBY PASCAL 1C C# JS JAVA";
    dict.close();
    Nonsense_Gen gen;
    gen.generate(15, 5);
    gen.generate(20, 4);
    gen.generate(12, 3);
}



#include <iostream>    //    .    .    .    .    .    .    ..    .    .    .    ..    .    .    .    .    ..        .    LAB04-A4
#include <fstream>
#include <vector>
#include <random>
#include <ctime>
using namespace std;
vector<int> random_walk(int up, int n) {
    static mt19937 gen(time(0));
    uniform_int_distribution<int> dist(1, 100);
    vector<int> v(n);
    for (int i = 1; i < n; i++)
        v[i] = v[i-1] + (dist(gen) <= up ? 1 : -1);
    return v;
}
int main() {
    ofstream f("RandomWalkReport.txt");
    int upV[] = {30, 50, 90}, nV[] = {10, 100, 1000};
    for (int up : upV) {
        for (int n : nV) {
            auto v = random_walk(up, n);
            f << "up=" << up << "% n=" << n << "\n";
            f << "v: ";
            for (int x : v) f << x << " ";
            f << "\nпоследний=" << v.back() << "\n";
            int upCnt = 0;
            for (int i = 1; i < n; i++) 
                if (v[i] == v[i-1] + 1) upCnt++;
            f << "p=" << (double)upCnt/(n-1)*100 << "% (теор " << up << "%)\n\n";
        }
    }
}




