using namespace std;
string rand_text(int len) {
    string s = "";
    for (int i = 0; i < len; i++) {
        char c;
        int r = rand() % 3;
        if (r == 0) c = 'a' + rand() % 26;
        else if (r == 1) c = 'A' + rand() % 26;
        else c = '0' + rand() % 10;
        s += c;
    }
    return s;
}

void cringe_virus(int k) {
    if (k <= 0) {
        return;
    }
    string name = "click_me_" + to_string(k) + ".txt";
    int len = rand() % 101;
    string text = rand_text(len);
    ofstream f(name);
    f << text;
    f.close();
    cout << "Создан: " << name << " (" << len << " символов)" << endl;
    cringe_virus(k - 1);
}
int main() {
    srand(time(0));
    int k;
    cout << "Введите число: ";
    cin >> k;
    cringe_virus(k);
}
