#include <iostream>  //  .  .  .  .  .  .  .  .  .  .  .  LAB05-A2
#include <chrono>
#include <fstream>
#include <iomanip>
#include <cassert>
using namespace std;
using namespace chrono;
long long ackermann(int m, int n) {
    if (m == 0) return n + 1;
    if (n == 0) return ackermann(m - 1, 1);
    return ackermann(m - 1, ackermann(m, n - 1));
}
void test() {
    assert(ackermann(0, 0) == 1);
    assert(ackermann(0, 1) == 2);
    assert(ackermann(1, 0) == 2);
    assert(ackermann(1, 1) == 3);
    assert(ackermann(2, 1) == 5);
    assert(ackermann(2, 2) == 7);
    assert(ackermann(3, 0) == 5);
    assert(ackermann(3, 1) == 13);
    assert(ackermann(3, 2) == 29);
    cout << "All tests passed!\n";
}
int main() {
    test();
    int params[6][2] = {{0,7}, {1,7}, {2,7}, {3,7}, {3,6}, {3,5}};
    ofstream f("akerman_report.txt");
    f << "Ackermann Function Report\n";
    f << "m\tn\tA(m,n)\tTime(ms)\n";
    for (auto& p : params) {
        int m = p[0], n = p[1];
        auto start = high_resolution_clock::now();
        long long res = ackermann(m, n);
        auto end = high_resolution_clock::now();
        auto ms = duration_cast<milliseconds>(end - start).count();
        f << m << "\t" << n << "\t" << res << "\t" << ms << "\n";
        cout << "A(" << m << "," << n << ") = " << res << " (" << ms << " ms)\n";
    }
    f.close();
    cout << "Report saved to akerman_report.txt";
}


#include <iostream>    //    .    .    .    .    .    .    .    .    LAB05-A3
#include <fstream>
#include <chrono>
using namespace std;
using namespace chrono;
const long long MOD = 1000000007;
long long pow_slow(long long x, int k) {
    if (k == 0) return 1;
    return (x * pow_slow(x, k - 1)) % MOD;
}
long long pow_fast(long long x, int k) {
    if (k == 0) return 1;
    if (k % 2 == 1) return (x * pow_fast(x, k - 1)) % MOD;
    long long y = pow_fast(x, k / 2);
    return (y * y) % MOD;
}
int main() {
    int k_val[] = {10, 100, 1000, 10000, 100000, 1000000, 10000000};
    ofstream f("pow_report.txt");
    f << "k\tpow_slow(ms)\tpow_fast(ms)\n";
    for (int k : k_val) {
        auto start = high_resolution_clock::now();
        pow_fast(2, k);
        auto end = high_resolution_clock::now();
        double fast_t = duration_cast<microseconds>(end - start).count() / 1000;
        double slow_t = -1;
        if (k <= 100000) {
            start = high_resolution_clock::now();
            pow_slow(2, k);
            end = high_resolution_clock::now();
            slow_t = duration_cast<microseconds>(end - start).count() / 1000;
        }
        f << k << "\t";
        if (slow_t >= 0) f << slow_t << "\t";
        else f << "N/A\t";
        f << fast_t << "\n";
    }
    f << "Сложность: pow_slow = O(k), pow_fast = O(log k)\n";
    f << "Вывод: pow_fast намного быстрее для больших k";
    cout << "Готово в pow_report.txt";
}


#include <iostream>    //    .    .    .    .    .    .    .    .    .    .    .    .    .    LAB05-A4
#include <fstream>
#include <chrono>
using namespace std;
using namespace chrono;
void hanoi(int n, char from, char to, char aux, ofstream& f) {
    if (n == 1) {
        f << "disk 1 from " << from << " to " << to << endl;
        return;
    }
    hanoi(n - 1, from, aux, to, f);
    f << "disk " << n << " from " << from << " to " << to << endl;
    hanoi(n - 1, aux, to, from, f);
}
int main() {
    int disks[] = {3, 5, 10, 15, 20};
    ofstream time_file("hanoi_time.txt");
    time_file << "n\ttime(ms)\tmoves\n";
    for (int n : disks) {
        string filename = "hanoi_" + to_string(n) + ".txt";
        ofstream f(filename);
        auto start = high_resolution_clock::now();
        hanoi(n, 'A', 'C', 'B', f);
        auto end = high_resolution_clock::now();
        f.close();
        long long moves = (1LL << n) - 1;
        long long ms = duration_cast<milliseconds>(end - start).count();
        time_file << n << "\t" << ms << "\t" << moves << "\n";
        cout << "n = " << n << " done (" << ms << " ms, " << moves << " moves)\n";
    }
    time_file.close();
    cout << "Files created: hanoi_3.txt, hanoi_5.txt, hanoi_10.txt, hanoi_15.txt, hanoi_20.txt\n";
    cout << "Time report saved in hanoi_time.txt";
}


#include <iostream>    //    .    .    .    .    .    .    .    .    .    LAB05-B1 (a)
#include <cassert>
using namespace std;
long long square_sum(int n) {
    if (n <= 0) {
        return 0;
    }
    return (long long)n * n + square_sum(n - 1);
}
void asserts() {
    assert(square_sum(0) == 0);
    assert(square_sum(1) == 1);
    assert(square_sum(2) == 5);
    assert(square_sum(3) == 14);
    assert(square_sum(5) == 55);
    assert(square_sum(10) == 385);
    assert(square_sum(-5) == 0);
    cout << "SUCCESS!" << endl;
}
int main() {
    asserts();
}


