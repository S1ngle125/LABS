using namespace std;
string to_hex(int n) {
    const string digits = "0123456789ABCDEF";
    if (n < 16) {
        return string(1, digits[n]);
    }
    return to_hex(n / 16) + digits[n % 16];
}
void test() {
    assert(to_hex(1) == "1");
    assert(to_hex(10) == "A");
    assert(to_hex(77) == "4D");
    assert(to_hex(1031) == "407");
    cout << "SUCCESS!" << endl;
}
int main() {
    test();
    int n;
    cout << "Введите число: ";
    cin >> n;
    cout << "0x" << to_hex(n) << endl;
}


#include <iostream>    //    .    .    .    .    .    .    .    .    .    .    .    LAB05-B3 (b)
#include <cassert>
#include <string>
using namespace std;
char bin4_to_hex(const string& s) {
    int val = (s[0]-'0')*8 + (s[1]-'0')*4 + (s[2]-'0')*2 + (s[3]-'0')*1;
    return val < 10 ? '0' + val : 'A' + (val - 10);
}
string bin_to_hex(const string& s) {
    if (s.empty()) return "";
    if (s.length() == 4) return string(1, bin4_to_hex(s));
    return bin_to_hex(s.substr(0, 4)) + bin_to_hex(s.substr(4));
}

string bin_to_hex_padded(const string& s) {
    int pad = (4 - s.length() % 4) % 4;
    return bin_to_hex(string(pad, '0') + s);
}

void test() {
    assert(bin_to_hex_padded("1") == "1");
    assert(bin_to_hex_padded("110") == "6");
    assert(bin_to_hex_padded("1100110") == "66");
    assert(bin_to_hex_padded("10010011101110") == "24EE");
    assert(bin_to_hex_padded("100111000100") == "9C4");
    cout << "SUCCESS" << endl;
}

int main() {
    test();
    string s;
    cout << "Введите бинарную строку: ";
    cin >> s;
    cout << "0x" << bin_to_hex_padded(s) << endl;
}


#include <iostream>    //    .    .    .    .    .    .    .    .    .    LAB05-B4
#include <vector>
#include <cassert>
#include <climits>
using namespace std;
int rec_min(const vector<int>& a, int i) {
    return i == 0 ? a[0] : min(a[i], rec_min(a, i - 1));
}
int rec_min(const vector<int>& a) {
    return a.empty() ? INT_MAX : rec_min(a, a.size() - 1);
}
void test() {
    assert(rec_min({5,2,8,1,9,3}) == 1);
    assert(rec_min({-5,-2,-8,-1,-9,-3}) == -9);
    assert(rec_min({7,7,7,7,7,7}) == 7);
    assert(rec_min({10,20,30,40,50,0}) == 0);
    assert(rec_min({0,10,20,30,40,50}) == 0);
    assert(rec_min({3,5,3,8,3,2}) == 2);
    cout << "SUCCESS!" << endl;
}
int main() {
    test();
    vector<int> arr = {15, 7, 23, 4, 42, 8};
    cout << "Минимум: " << rec_min(arr) << endl;
}


