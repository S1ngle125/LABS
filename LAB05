#include <iostream>    //    .    .    .    .    .    .    .    .    LAB05-B2  
using namespace std;
void rec_triangle(int n, int current = 1) {
    if (current > n + 2) {
        return;
    }
    int len;
    if (current == 1) {
        len = 1;
    }
    else if (current <= n + 2) {
        len = current;
    }
    for (int i = 1; i <= len; i++) {
        cout << (i == 1 || i == len ? '*' : '+');
    }
    cout << endl;
    rec_triangle(n, current + 1);
}
int main() {
    int n;
    cout << "Введите n: ";
    cin >> n;
    rec_triangle(n);
}


#include <iostream>    //    .    .    .    .    .    .    .    .        .    LAB05-B3 (a)
