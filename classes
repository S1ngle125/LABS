class Circle : public Vector {
private:
    double radius;
public:
    Circle() : Vector(0, 0), radius(1) {}
    Circle(double x1, double y1, double r) : Vector(x1, y1), radius(r) {}
    Circle(double r) : Vector(0, 0), radius(r) {}
    Circle(const Vector& center) : Vector(center.getx(), center.gety()), radius(1) {}
    double getRadius() const { 
        return radius; 
    }
    double getCenterX() const { 
        return getx(); 
    }
    double getCenterY() const { 
        return gety(); 
    }
    Vector getCenter() const { return Vector(getx(), gety()); }
    void setRadius(double r) { 
        radius = r;
    }
    double getArea() const {
        return 3.1415 * radius * radius;
    }
    double getRound() const {
        return 2 * 3.1415 * radius;
    }
    double getDiameter() const {
        return 2 * radius;
    }
    Circle operator+(const Circle& other) const {
        double totalArea = this->getArea() + other.getArea();
        double newRadius = sqrt(totalArea / 3.1415);
        Vector newCenter = this->getCenter() + other.getCenter();
        return Circle(newCenter.getx(), newCenter.gety(), newRadius);
    }
    void print() const {
        cout << "Окружность:" << endl;
        cout << "  Центр: (" << getx() << ", " << gety() << ")" << endl;
        cout << "  Радиус: " << radius << endl;
        cout << "  Диаметр: " << getDiameter() << endl;
        cout << "  Длина окружности: " << getRound() << endl;
        cout << "  Площадь: " << getArea() << endl;
    }
};
int main() {
    cout << "=== ТЕСТ КЛАССА CIRCLE ===" << endl;
    Circle c1;
