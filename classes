#include<iostream>  //  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  LAB03-A1 + LAB03-A2
#include<string>
#include<vector>
using namespace std;
class IT_Student {
    string name;
    string surname;
    int g_num;
    int grades[5];
    string lan;
    double gpa;
    void calcGPA() {
        double sum = 0;
        for (int i = 0; i < 5; i++) {
            sum += grades[i];
        }
        gpa = sum / 5;
    }
public:
    IT_Student() : gpa(0.0) {}
    void input() {
        cout << "Enter your name: ";
        cin >> name;
        
        cout << "Enter your surname: ";
        cin >> surname;
        
        cout << "Enter your group number (1 or 2): ";
        cin >> g_num;
        
        cout << "Enter your grades(exactly 5): ";
        for (int i = 0; i < 5; ++i) {
            cin >> grades[i];
        }
        cout << "Enter your favourite language: ";
        cin >> lan;
        calcGPA();
    }
    void output() {
        cout << endl;
        cout << "Name: " << name << endl;
        cout << "Surname: " << surname << endl;
        cout << "Group number: " << g_num << endl;
        cout << "Grades: ";
        for (int i = 0; i < 5; i++) {
            cout << grades[i] << " ";
        }
        cout << endl;
        cout << "Favourite language: " << lan << endl;
        cout << "GPA: " << gpa << endl;
        cout << "===============================" << endl;
    }
    void updateGrades() {
        cout << "Enter new grades(exactly 5) for " << surname << " " << name << ": ";
        for (int i = 0; i < 5; ++i) {
            cin >> grades[i];
        }
        calcGPA();
        cout << "Grades updated successfully! New GPA for " << surname << " " << name << ": " << gpa << endl;
    }
    string getName() {
        return name;
    }
    string getSurname() {
        return surname;
    }
};
int main() {
    vector<IT_Student> students;
    int num;
    cout << "How many students will you add?: ";
    cin >> num;
    for (int i = 0; i < num; i++) {
        cout << "===== Student №" << (i + 1) << " =====" << endl;
        IT_Student student;
        student.input();
        students.push_back(student);
    }
    cout << "=====  ALL STUDENTS  =====" << endl;
    for (int i = 0; i < students.size(); i++) {
        cout << "Student №" << (i+1);
        students[i].output();
    }
    int x;
    cout << "Do you want to update grades? (1 or 0): ";
    cin >> x;
    if (x == 1) {
        int w;
        int count = 1;
        cout << "How many students will have updated grades?: ";
        cin >> w;
        while (w > 0) {
            cout << "====UPDATING GRADES====" << endl;
            string name, surname;
            cout << "Enter name of student №" << count << ": ";
            cin >> name;
            cout << "Enter surname of student №" << count << ": ";
            cin >> surname;
            for (int i = 0; i < 5; ++i) {
                if (students[i].getName() == name and students[i].getSurname() == surname) {
                    students[i].updateGrades();
                    break;
                }
            }
            w--;
            count++;
        }
    }
    else {
        cout << endl;
    }
}



