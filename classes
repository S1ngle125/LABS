#include<iostream>  //  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  LAB03-A1 + LAB03-A2
#include<string>
#include<vector>
using namespace std;
class IT_Student {
    string name;
    string surname;
    int g_num;
    int grades[5];
    string lan;
    double gpa;
public:
    void calcGPA() {
        double sum = 0;
        for (int i = 0; i < 5; i++) {
            sum += grades[i];
        }
        gpa = sum / 5;
    }
    void input() {
        cout << "Enter your name: ";
        cin >> name;
        
        cout << "Enter your surname: ";
        cin >> surname;
        
        cout << "Enter your group number (1 or 2): ";
        cin >> g_num;
        
        cout << "Enter your grades(5): ";
        for (int i = 0; i < 5; ++i) {
            cin >> grades[i];
        }
        cout << "Enter your favourite language: ";
        cin >> lan;
        calcGPA();
    }
    void output() {
        cout << endl;
        cout << "Name: " << name << endl;
        cout << "Surname: " << surname << endl;
        cout << "Group number: " << g_num << endl;
        cout << "Grades: ";
        for (int i = 0; i < 5; i++) {
            cout << grades[i] << " ";
        }
        cout << endl;
        cout << "Favourite language: " << lan << endl;
        cout << "GPA: " << gpa << endl;
        cout << "===============================" << endl;
    }
};
int main() {
    vector<IT_Student> students;
    int num;
    cout << "How many students will you add?: ";
    cin >> num;
    for (int i = 0; i < num; i++) {
        cout << "===== Student №" << (i + 1) << " =====" << endl;
        IT_Student student;
        student.input();
        students.push_back(student);
    }
    cout << "=====  ALL STUDENTS  =====" << endl;
    for (int i = 0; i < students.size(); i++) {
        cout << "Student №" << (i+1);
        students[i].output();
    }
}
