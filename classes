#include<iostream>    //    .    .    .    .    .    .    .    .    .    .    .    .    .    LAB03-A4
using namespace std;
class Matrix {
    double a, b, c;
    double d, e, f;
    double g, h, i;
public:
    Matrix() : a(1), b(0), c(0), d(0), e(1), f(0), g(0), h(0), i(1) {}
    Matrix(double a1, double b1, double c1, double d1, double e1, double f1, double g1, double h1, double i1) : a(a1), b(b1), c(c1), d(d1), e(e1), f(f1), g(g1), h(h1), i(i1) {}
    double determinant() const {
        return a * (e * i - f * h) - b * (d * i - f * g) + c * (d * h - e * g);
    }
    Matrix transpose() {
        return Matrix(a, d, g, b, e, h, c, f, i);
    }
    void output() const {
        cout << a << " " << b << " " << c << endl;
        cout << d << " " << e << " " << f << endl;
        cout << g << " " << h << " " << i << endl;
    }
};
int main() {
    cout << "Единичная матрица: " << endl;
    Matrix m1;
    m1.output();
    cout << "Определитель: " << m1.determinant() << endl;
    Matrix m2(1, 2, 3, 4, 5, 6, 7, 8, 9);
    m2.output();
    Matrix m2t = m2.transpose();
    cout << "Транспонирование: " << endl;
    m2t.output();
    cout << "Новая матрица: " << endl;
    Matrix m3(3, 4, 5, 6, 2, 4, 9, 8, 1);
    m3.output();
    cout << "Определитель: " << m3.determinant() << endl;
    cout << "Оригинальная матрица: " << endl;
    m3.output();
    Matrix m3t = m3.transpose();
    cout << "Транспонированная матрица: " << endl;
    m3t.output();
}



#include<iostream>    //    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    LAB03-A5
using namespace std;
class Monster {
    int hp;
    int dmg;
public:
    Monster() {
        hp = 100;
        dmg = 10;
        cout << "I am born!" << endl;
    }
    Monster(int health, int damage) {
        hp = health;
        dmg = damage;
        cout << "I am born!" << endl;
    }
    ~Monster() {
        cout << "I am dying, AAAAA!" << endl;
    }
    int gethp() const {
        return hp;
    }
    void PVP(Monster &enemy) {
        cout << "Наш монстр (HP: " << hp << ", DMG: " << dmg << ")" << endl;
        cout << "Враг (HP: " << enemy.hp << ", DMG: " << enemy.dmg << ")" << endl;
        int round = 1;
        while (hp > 0 and enemy.hp > 0) {
            cout << "РАУНД " << round << endl;
            cout << "Наш монстр атакует и наносит " << dmg << " урона!" << endl;
            enemy.hp -= dmg;
            if (enemy.hp <= 0) {
                enemy.hp = 0;
                cout << "Враг получает урон и у него осталось " << enemy.hp << " здоровья!" << endl;
                cout << "Враг проиграл!" << endl;
                cout << "Наш монстр победил!" << endl;
                break;
            }
            else {
                cout << "Враг получает урон и у него осталось " << enemy.hp << " здоровья!" << endl;
            }
            cout << "Враг атакует и наносит " << enemy.dmg << " урона!" << endl;
            hp -= enemy.dmg;
            if (hp <= 0) {
                hp = 0;
                cout << "Наш монстр получает урон и у него осталось " << hp << " здоровья!" << endl;
                cout << "Наш монстр проиграл!" << endl;
                cout << "Враг победил!" << endl;
                break;
            }
            else {
                cout << "Наш монстр получает урон и у него осталось " << hp << " здоровья!" << endl;
            }
            round++;
        }
    }
};
int main() {
    Monster m1;
    Monster m2(200, 15);
    cout << "Битва начинается!" << endl;
    m2.PVP(m1);
}


#include<iostream>    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    . LAB03-B1
#include<vector>
using namespace std;
class Monster {
  int health;
  int damage;
 public:
    Monster() : health(100), damage(10) {}
    Monster(int h, int d) : health(h), damage(d) {}
    void attack (Monster& other) {
        other.health -= damage;
    }
    bool isAlive() {
        return health > 0;
    }
};
class MonsterArmy  {
    vector<Monster> monsters;
public:
    MonsterArmy() {}
    MonsterArmy(int count) {
        for (int i = 0; i < count; ++i) {
            monsters.push_back(Monster(100 + i*10, 10 + i*2));
        }
    }
    MonsterArmy(const Monster& m) {
        monsters.push_back(m);
    }
    
    void BattleRoyale() {
        if (monsters.size() == 0) {
            cout << "No monsters" << endl;
        }
        else {
            vector<Monster> fighters = monsters;
            int winner = 0;
            for (int i = 1; i < fighters.size(); i++) {
                cout << "Fight: " << winner << " vs " << i << endl;
                while (fighters[winner].isAlive() && fighters[i].isAlive()) {
                    fighters[winner].attack(fighters[i]);
                    if (fighters[i].isAlive()) {
                      fighters[i].attack(fighters[winner]);
                  }
                }
                if (!fighters[winner].isAlive()) {
                    winner = i;
                }
                cout << "Winner: " << winner << endl;
            }
        cout << "FINAL WINNER: Monster " << winner << endl;
        }
    }
};
int main() {
    MonsterArmy army(3);
    army.BattleRoyale();
}


#include<iostream>    .    .    .    .    .        .    .    .    .    .    .    .    LAB03-B2
#include<vector>
#include<cmath>
using namespace std;

class Vector {
    double x, y, z;
public:
    Vector() {
        x = 0;
        y = 0;
        z = 0;
    }
    
    Vector(double x1, double y1, double z1) {
        x = x1;
        y = y1;
        z = z1;
    }
    
    double getx() {
        return x;
    }
    
    double gety() {
        return y;
    }
    
    double getz() {
        return z;
    }
    
    void setx(double newx) {
        x = newx;
    }
    
    void sety(double newy) {
        y = newy;
    }
    
    void setz(double newz) {
        z = newz;
    }
    
    Vector operator+(const Vector& other) const {
        return Vector(x + other.x, y + other.y, z + other.z);
    }
    
    Vector operator*(double scalar) const {
        return Vector(x * scalar, y * scalar, z * scalar);
    }
    
    double operator*(const Vector& other) const {
        return x * other.x + y * other.y + z * other.z;
    }
    
    double length() const {
        return sqrt((*this) * (*this));
    }
    
    void print() const {
        cout << "(" << x << ", " << y << ", " << z << ")";
    }
};
Vector operator*(double scalar, const Vector& v) {
    return v * scalar;
}
int maxlen(const vector<Vector>& vectors) {
    if (vectors.empty()) return -1;
    int maxIndex = 0;
    double maxLength = vectors[0].length();
    for (size_t i = 1; i < vectors.size(); ++i) {
        double currentLength = vectors[i].length();
        if (currentLength > maxLength) {
            maxLength = currentLength;
            maxIndex = i;
        }
    }
    
    return maxIndex;
}
int minlen(const vector<Vector>& vectors) {
    if (vectors.empty()) return -1;
    
    int minIndex = 0;
    double minLength = vectors[0].length();
    
    for (size_t i = 1; i < vectors.size(); ++i) {
        double currentLength = vectors[i].length();
        if (currentLength < minLength) {
            minLength = currentLength;
            minIndex = i;
        }
    }
    
    return minIndex;
}

int main() {                 
    cout << "=== Тест базового функционала ===" << endl;
    Vector v1;
    Vector v2(2.5, 4.3, 6.8);
    cout << "v2 coordinates: " << v2.getx() << ", " << v2.gety() << ", " << v2.getz() << endl;
    v1.setx(7);
    v1.sety(14);
    v1.setz(21);
    cout << "v1 coordinates: " << v1.getx() << ", " << v1.gety() << ", " << v1.getz() << endl;
    
    cout << "\n=== Тест оператора + ===" << endl;
    Vector v3 = v1 + v2;
    cout << "v1 + v2 = ";
    v3.print();
    cout << endl;
    
    cout << "\n=== Тест оператора * (вектор * скаляр) ===" << endl;
    Vector v4 = v1 * 2.5;
    cout << "v1 * 2.5 = ";
    v4.print();
    cout << endl;
    
    cout << "\n=== Тест оператора * (скаляр * вектор) ===" << endl;
    Vector v5 = 3.0 * v2;
    cout << "3.0 * v2 = ";
    v5.print();
    cout << endl;
    
    cout << "\n=== Тест скалярного произведения ===" << endl;
    double dot = v1 * v2;
    cout << "v1 * v2 (dot product) = " << dot << endl;
    
    cout << "\n=== Тест метода length() ===" << endl;
    cout << "|v1| = " << v1.length() << endl;
    cout << "|v2| = " << v2.length() << endl;
    cout << "|v3| = " << v3.length() << endl;
    
    cout << "\n=== Тест функций maxlen и minlen ===" << endl;
    vector<Vector> vectors;
    
    vectors.push_back(Vector(1, 0, 0));
    vectors.push_back(Vector(3, 4, 0)); 
    vectors.push_back(Vector(1, 1, 1));
    vectors.push_back(Vector(5, 12, 0));                         
    
    for (size_t i = 0; i < vectors.size(); ++i) {
        cout << "Vector " << i << ": ";
        vectors[i].print();
        cout << ", length = " << vectors[i].length() << endl;
    }
    
    int longest = maxlen(vectors);
    int shortest = minlen(vectors);
    cout << "\nСамый длинный вектор: индекс " << longest;
    cout << " (длина = " << vectors[longest].length() << ")" << endl;
    cout << "Самый короткий вектор: индекс " << shortest;
    cout << " (длина = " << vectors[shortest].length() << ")" << endl;
    cout << "\n=== Тест с одинаковыми длинами ===" << endl;
    vector<Vector> vectors2;
    vectors2.push_back(Vector(3, 4, 0));
    vectors2.push_back(Vector(5, 0, 0));
    vectors2.push_back(Vector(0, 5, 0));
    
    for (size_t i = 0; i < vectors2.size(); ++i) {
        cout << "Vector " << i << ": ";
        vectors2[i].print();
        cout << ", length = " << vectors2[i].length() << endl;
    }
    
    cout << "Самый длинный: индекс " << maxlen(vectors2) << endl;
    cout << "Самый короткий: индекс " << minlen(vectors2) << endl;
}
