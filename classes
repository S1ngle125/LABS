    cout << "c3 только радиус: " << endl;
    c3.print();
    cout << "c4 только центр: " << endl;
    c4.print();
    Circle c5 = c2 + c3;
    cout << "c5 = c2 + c3:" << endl;
    c5.print();
}



#include<iostream>    .    .    .    .    .    .    .    .    .    .    .    .    .    . LAB03-B5
using namespace std;
class Matrix {
    double a, b, c;
    double d, e, f;
    double g, h, i;
public:
    Matrix() : a(1), b(0), c(0), d(0), e(1), f(0), g(0), h(0), i(1) {}
    Matrix(double a1, double b1, double c1, double d1, double e1, double f1, double g1, double h1, double i1) : a(a1), b(b1), c(c1), d(d1), e(e1), f(f1), g(g1), h(h1), i(i1) {}
    double get(int r, int s) const {
        if (r == 0 && s == 0) return a;
        if (r == 0 && s == 1) return b;
        if (r == 0 && s == 2) return c;
        if (r == 1 && s == 0) return d;
        if (r == 1 && s == 1) return e;
        if (r == 1 && s == 2) return f;
        if (r == 2 && s == 0) return g;
        if (r == 2 && s == 1) return h;
        if (r == 2 && s == 2) return i;
    }
    double determinant() const {
        return a * (e * i - f * h) - b * (d * i - f * g) + c * (d * h - e * g);
    }
    Matrix transpose() {
        return Matrix(a, d, g, b, e, h, c, f, i);
    }
    void output() const {
        cout << a << " " << b << " " << c << endl;
        cout << d << " " << e << " " << f << endl;
        cout << g << " " << h << " " << i << endl;
    }
    Matrix operator+(const Matrix& other) const {
        return Matrix(
            a + other.a, b + other.b, c + other.c,
            d + other.d, e + other.e, f + other.f,
            g + other.g, h + other.h, i + other.i
        );
    }
    Matrix operator*(double scalar) const {
        return Matrix(
            a * scalar, b * scalar, c * scalar,
            d * scalar, e * scalar, f * scalar,
            g * scalar, h * scalar, i * scalar
        );
    }
    Matrix operator*(const Matrix& other) const {
        return Matrix(
            a * other.a + b * other.d + c * other.g,
            a * other.b + b * other.e + c * other.h,
            a * other.c + b * other.f + c * other.i,
            
            d * other.a + e * other.d + f * other.g,
            d * other.b + e * other.e + f * other.h,
            d * other.c + e * other.f + f * other.i,

            g * other.a + h * other.d + i * other.g,
            g * other.b + h * other.e + i * other.h,
            g * other.c + h * other.f + i * other.i
        );
    }
    Matrix power(int k) const {
        if (k < 0) {
            return *this;
        }
        if (k == 0) {
            return Matrix();
        }
        Matrix result = *this;
        for (int expo = 1; expo < k; expo++) {
            result = result * (*this);
        }
        return result;
    }
};
int main() {
    cout << "Единичная матрица: " << endl;
    Matrix m1;
    m1.output();
    cout << "Определитель: " << m1.determinant() << endl;
    cout << "m2 Matrix: " << endl;
    Matrix m2(1, 2, 3, 4, 5, 6, 7, 8, 9);
    m2.output();
    Matrix m2t = m2.transpose();
    cout << "Транспонирование: " << endl;
    m2t.output();
    cout << "(m3) Новая матрица: " << endl;
    Matrix m3(3, 4, 5, 6, 2, 4, 9, 8, 1);
    m3.output();
    cout << "Определитель: " << m3.determinant() << endl;
    cout << "Оригинальная матрица: " << endl;
