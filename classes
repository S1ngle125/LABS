#include<iostream>  //  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  .  LAB03-A1 + LAB03-A2
#include<string>
#include<vector>
using namespace std;
class IT_Student {
    string name;
    string surname;
    int g_num;
    int grades[5];
    string lan;
    double gpa;
public:
    void calcGPA() {
        double sum = 0;
        for (int i = 0; i < 5; i++) {
            sum += grades[i];
        }
        gpa = sum / 5;
    }
    void input() {
        cout << "Enter your name: ";
        cin >> name;
        
        cout << "Enter your surname: ";
        cin >> surname;
        
        cout << "Enter your group number (1 or 2): ";
        cin >> g_num;
        
        cout << "Enter your grades(5): ";
        for (int i = 0; i < 5; ++i) {
            cin >> grades[i];
        }
        cout << "Enter your favourite language: ";
        cin >> lan;
        calcGPA();
    }
    void output() {
        cout << endl;
        cout << "Name: " << name << endl;
        cout << "Surname: " << surname << endl;
        cout << "Group number: " << g_num << endl;
        cout << "Grades: ";
        for (int i = 0; i < 5; i++) {
            cout << grades[i] << " ";
        }
        cout << endl;
        cout << "Favourite language: " << lan << endl;
        cout << "GPA: " << gpa << endl;
        cout << "===============================" << endl;
    }
};
int main() {
    vector<IT_Student> students;
    int num;
    cout << "How many students will you add?: ";
    cin >> num;
    for (int i = 0; i < num; i++) {
        cout << "===== Student №" << (i + 1) << " =====" << endl;
        IT_Student student;
        student.input();
        students.push_back(student);
    }
    cout << "=====  ALL STUDENTS  =====" << endl;
    for (int i = 0; i < students.size(); i++) {
        cout << "Student №" << (i+1);
        students[i].output();
    }
}


#include<iostream>    //    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    .    LAB03-A3
using namespace std;
class Vector {
    double x,y,z;
public:
    Vector() {
        x = 0;
        y = 0;
        z = 0;
    }
    Vector(double x1, double y1, double z1) { //x1 - координата x, y1 - координата y и тд
        x = x1;
        y = y1;
        z = z1;
    }
    double getx() {
        return x;
    }
    double gety() {
        return y;
    }
    double getz() {
        return z;
    }
    void setx(double newx) {
        x = newx;
    }
    void sety(double newy) {
        y = newy;
    }
    void setz(double newz) {
        z = newz;
    }
};
int main() {
    Vector v1;
    Vector v2(2.5, 4.3, 6.8);
    cout << "v2 coordinates: " << v2.getx() << ", " << v2.gety() << ", " << v2.getz() << endl;
    v1.setx(7);
    v1.sety(14);
    v1.setz(21);
    cout << "v1 coordinates: " << v1.getx() << ", " << v1.gety() << ", " << v1.getz() << endl;
}



#include<iostream>    //    .    .    .    .    .    .    .    .    .    .    .    .    .    LAB03-A4
using namespace std;
class Matrix {
    double a, b, c;
    double d, e, f;
    double g, h, i;
public:
    Matrix() : a(1), b(0), c(0), d(0), e(1), f(0), g(0), h(0), i(1) {}
    Matrix(double a1, double b1, double c1, double d1, double e1, double f1, double g1, double h1, double i1) : a(a1), b(b1), c(c1), d(d1), e(e1), f(f1), g(g1), h(h1), i(i1) {}
    double determinant() const {
        return a * (e * i - f * h) - b * (d * i - f * g) + c * (d * h - e * g);
    }
    Matrix transpose() {
        return Matrix(a, d, g, b, e, h, c, f, i);
    }
    void output() const {
        cout << a << " " << b << " " << c << endl;
        cout << d << " " << e << " " << f << endl;
        cout << g << " " << h << " " << i << endl;
    }
};
int main() {
    cout << "Единичная матрица: " << endl;
    Matrix m1;
    m1.output();
    cout << "Определитель: " << m1.determinant() << endl;
    Matrix m2(1, 2, 3, 4, 5, 6, 7, 8, 9);
    m2.output();
    Matrix m2t = m2.transpose();
    cout << "Транспонирование: " << endl;
    m2t.output();
    cout << "Новая матрица: " << endl;
    Matrix m3(3, 4, 5, 6, 2, 4, 9, 8, 1);
    m3.output();
    cout << "Определитель: " << m3.determinant() << endl;
    cout << "Оригинальная матрица: " << endl;
    m3.output();
    Matrix m3t = m3.transpose();
    cout << "Транспонированная матрица: " << endl;
    m3t.output();
}
